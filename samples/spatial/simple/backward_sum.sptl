/**
 * Simple vertical aggregation without any communication
 **/
kernel @add<N, K>(stream<f32>[N, N] readonly a,
                  stream<f32>[N, N] writeonly out) {
    place u16 i, u16 j in [0:N, 0:N] {
        f32[K] local_a;
    }
    compute u16 i, u16 j in [0:N, 0:N] {
        await receive(local_a, a[i, j]);
        for i32 k in [1:K] {
            local_a[K-k-1] = local_a[K-k] + local_a[K-k-1];
        }
        await send(local_a, out[i, j]);
    }
}