/**
 * Simple matrix copy without any communication
 **/
kernel @copy<N>(stream<f32, 1>[N, N] readonly a,
               stream<f32, 1>[N, N] writeonly out) {
    place u16 i, u16 j in [0:N, 0:N] {
        f32 local;
    }
    compute u16 i, u16 j in [0:N, 0:N] {
        await receive(local, a[i, j]);
        await send(local, out[i, j]);
    }
}
