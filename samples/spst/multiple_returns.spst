// Version with materialize to prevent recomputation, uses short-hand syntax
// Before type-inference
%pres_1, %pres_2 = spst.program (%in) {} :
       field<[?, ?, ?], f32>
    -> field<[?, ?, ?], f32>, field<[?,?,?], f32>
{
    %res_1, %res_2 = spst.computation (%in)
    {
        schedule =  PARALLEL,
        interval = [0:None, 0:None, 0: None]
    } : view<[?,?,?], {(?, ?, ?)}, f32>
      -> view<[?,?,?], {(?, ?, ?)}, f32>, view<[?,?,?], {(?, ?, ?)}, f32>
    {
        %out_1, %out_2 = spst.statement(%in)
                : view<[?,?,?], {(?, ?, ?)}, f32>
                -> view<[?,?,?], {(?, ?, ?)}, f32>, view<[?,?,?], {(?, ?, ?)}, f32>
            {
                return %in[0, 0, 0] + %in[-1, 0, 0],  4 * %in[-1, 0, 0]
            }
        %out_mat_1 = spst.materialize(%out_1) : view<[?,?,?], {(?, ?, ?)}, f32>
                                             -> view<[?,?,?], {(?, ?, ?)}, f32>
        %out_mat_2 = spst.materialize(%out_2) : view<[?,?,?], {(?, ?, ?)}, f32>
                                             -> view<[?,?,?], {(?, ?, ?)}, f32>

        %out_3 = spst.statement(%out_mat_1)
            : view<[?,?,?], {(?, ?, ?)}, f32>
            -> view<[?,?,?], {(?, ?, ?)}, f32> {
                return %out_mat_1[0, 0, 0] - %out_mat_1[0, 1, 0]
            }
        %out_4 = spst.statement(%out_mat_2)
            : view<[?,?,?], {(?, ?, ?)}, f32>
            -> view<[?,?,?], {(?, ?, ?)}, f32> {
                return 2 * %out_mat_2[0, 1, 0]
            }
        return %out_3, %out_4 : view<[?,?,?], {(?, ?, ?)}, f32>, view<[?,?,?], {(?, ?, ?)}, f32>
    }
    return %res_1, %res_2: view<[?,?,?], {(?, ?, ?)}, f32>, view<[?,?,?], {(?, ?, ?)}, f32>
}