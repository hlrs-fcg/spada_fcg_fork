// Version with materialize to prevent recomputation, uses short-hand syntax
// Before type-inference
%pres = spst.program (%in) {} :
       field<[?, ?, ?], f32>
    -> field<[?, ?, ?], f32>
{
    %res = spst.computation (%in)
    {
        schedule =  PARALLEL,
        interval = [0:None, 0:None, 0: None]
    } : view<[?,?,?],
              {(?, ?, ?)}, f32>
      -> view<[?,?,?], {(?, ?, ?)}, f32>
    {
        %out_1 = spst.statement(%in)
                : view<[?,?,?],
                  {(?, ?, ?)}, f32>
                -> view<[?,?,?], {(?, ?, ?)}, f32>
            {
                return -4.0 * %in[0, 0, 0] + %in[-1, 0, 0] + %in[1, 0, 0] + %in[0, -1, 0] + %in[0, 1, 0]
            }
        %out_mat = spst.materialize(%out_1) : view<[?,?,?], {(?, ?, ?)}, f32>
                                             -> view<[?,?,?], {(?, ?, ?)}, f32>
        %out_2 = spst.statement(%out_1, %out_mat)
            : view<[?,?,?], {(?, ?, ?)}, f32>,
              view<[?,?,?], {(?, ?, ?)}, f32>
            -> view<[?,?,?], {(?, ?, ?)}, f32> {
                return %out_1[0, 0, 0] + %out_mat[0, 1, 0]
            }
        return %out_2 : view<[?,?,?], {(?, ?, ?)}, f32>
    }
    return %res : view<[?,?,?], {(?, ?, ?)}, f32>
}