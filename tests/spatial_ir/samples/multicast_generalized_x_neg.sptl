/**
 * Generalized x-axis negative-direction multicast.
 * Sender at PE (N-1, 0) multicasts WEST via range [-START:-N]
 * to PEs (0,0)…(N-START-1,0).
 * PEs (N-START,0)…(N-2,0) are relay-only when START > 1.
 * Only receivers write to out; the sender is excluded from the output.
 *
 * Parameters:
 *   N     – total number of PEs in x (grid 0..N-1)
 *   START – magnitude of offset to first receiver (≥ 1)
 *
 * Expected: OUT_out[k, 0, 0] == inp[0, 0, 0]  for k in 0..N-START-1
 **/
kernel @multicast_generalized_x_neg<N, START>(
    stream<f32, 2>[1, 1]       readonly  inp,
    stream<f32, 2>[N-START, 1] writeonly out
) {
    place u16 i, u16 j in [0:N, 0:1] {
        f32[2] val
    }

    dataflow u16 i, u16 j in [0:N, 0:1] {
        stream<f32> s = relative_stream([-START:-N], 0) {
            hops    = auto,
            channel = 0
        }
    }

    // Sender: last PE in x; loads from inp[i,j] and multicasts westward (does not write to out).
    compute u16 i, u16 j in [N-1:N, 0:1] {
        await receive(val, inp[i-(N-1), j])
        await send(val, s)
    }

    // Receivers: PEs 0..N-START-1; write to contiguous output.
    compute u16 i, u16 j in [0:N-START, 0:1] {
        await receive(val, s)
        await send(val, out[i, j])
    }
}
